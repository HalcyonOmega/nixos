+def _append_hf_download_retry(lines: list[str], command: str, *, stdin: str = " < /dev/null", attempts: int = 5) -> None:
+    """Append a retry loop for transient HuggingFace download failures."""
+    lines.append("_ec=1")
+    lines.append(f"for _try in $(seq 1 {attempts}); do")
+    lines.append(f"  {command}{stdin}")
+    lines.append("  _ec=$?")
+    lines.append("  if [ $_ec -eq 0 ]; then break; fi")
+    lines.append(f"  if [ $_try -lt {attempts} ]; then")
+    lines.append('    _delay=$(( _try * 10 ))')
+    lines.append('    echo ""')
+    lines.append('    echo "[odysseus] HuggingFace download failed with exit $_ec; retrying in ${_delay}s (attempt ${_try}/5)..."')
+    lines.append('    sleep "$_delay"')
+    lines.append("  fi")
+    lines.append("done")
+
 def setup_cookbook_routes() -> APIRouter:
